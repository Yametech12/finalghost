{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/ai/chat.ts": {
      "runtime": "nodejs20.x"
    },
    "api/ai/test-key.ts": {
      "runtime": "nodejs20.x"
    },
    "api/ai/models.ts": {
      "runtime": "nodejs20.x"
    },
    "api/ai/diagnostics.ts": {
      "runtime": "nodejs20.x"
    },
    "api/auth/send-code.ts": {
      "runtime": "nodejs20.x"
    },
    "api/auth/verify-code.ts": {
      "runtime": "nodejs20.x"
    },
    "api/health.ts": {
      "runtime": "nodejs20.x"
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        }
      ]
    }
  ]
}